{
  "productName": "Bamako",
  "version": "0.1.0",
  "identifier": "build.conductor.bamako",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5274",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Bamako",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/velesdb-server"]
  }
}
